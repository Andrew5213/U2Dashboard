# ClickUp
CLICKUP_API_TOKEN=your_clickup_api_token
CLICKUP_WEBHOOK_SECRET=your_webhook_secret
CLICKUP_TEAM_ID=your_team_id
CLICKUP_DEFAULT_SPACE_ID=your_space_id

# Airbox (AltoQI Visus Workflow)
# Gere a API Key em: AltoQI Visus Workflow -> Configuracoes -> Integracoes -> API
AIRBOX_API_KEY=your_airbox_api_key
AIRBOX_BASE_URL=https://workflow-api.altoqivisus.com.br
AIRBOX_DEFAULT_ENTITY_TYPE=Agreement

# Database (SQLite sempre — nao ha Postgres)
# Local (padrao):
DATABASE_URL=sqlite+aiosqlite:///./sync.db
# Producao (Railway): o filesystem do container e apagado a cada redeploy.
# Para os RDOs nao serem perdidos, crie um Volume montado em /data no servico
# (Railway dashboard -> Service -> Settings -> Volumes) e defina:
# DATABASE_URL=sqlite+aiosqlite:////data/sync.db
# CIVIL_UPLOADS_DIR=/data/uploads
# DOCUMENTS_DIR=/data/documents

# Diretorio das fotos do RDO (servido em /uploads). Em producao, aponte para o Volume:
CIVIL_UPLOADS_DIR=./uploads

# Modulo RDO Diario + Controle de Progresso (temporariamente desativado).
# Defina como true para reativar as paginas /rdo e /progresso-civil e seus links na sidebar.
RDO_MODULE_ENABLED=false

# Diretorio dos PDFs da area de Documentacoes. Em producao, aponte para o Volume:
DOCUMENTS_DIR=./documents

# App
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=INFO

# Sync
POLLING_INTERVAL_SECONDS=60
SYNC_ENABLED=true

# Dashboard / Cache
DASHBOARD_ENABLED=true
CACHE_REFRESH_INTERVAL_SECONDS=300
CACHE_REFRESH_ON_STARTUP=true
SSE_KEEPALIVE_SECONDS=15.0

# Chat / AI Agent
# Para desabilitar completamente: CHAT_ENABLED=false ou deixe ANTHROPIC_API_KEY vazio
CHAT_ENABLED=true
ANTHROPIC_API_KEY=
